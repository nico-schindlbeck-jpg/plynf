# Slack bot credentials — generate at https://api.slack.com/apps/<your-app>/install
SLACK_BOT_TOKEN=xoxb-…
SLACK_SIGNING_SECRET=…
# Socket Mode token (xapp-…) lets the bot run behind a NAT / on a laptop
# without exposing a public URL. Production should use HTTP mode and
# remove this var.
SLACK_APP_TOKEN=xapp-…

# Plynf proxy
PLYNF_URL=http://localhost:7430
PLYNF_API_KEY=demo

# Optional — model used when the bot needs to draft a reply itself.
# When empty, the bot just echoes shaped tool data back into the channel.
PLYNF_MODEL=gpt-4o

# Optional logging level: error | warn | info | debug
LOG_LEVEL=info

# ── OAuth installer (npm run oauth) — only needed for "Add to Slack" ──
SLACK_CLIENT_ID=…
SLACK_CLIENT_SECRET=…
# Public URL where the OAuth handler is reachable. Slack appends
# /slack/oauth/callback to this for the redirect.
PUBLIC_URL=https://slack-install.plynf.com
# Where installed-workspace records are persisted (JSONL).
INSTALLATIONS_PATH=./data/installations.jsonl
