# Slack bot credentials — generate at https://api.slack.com/apps/<your-app>/install
SLACK_BOT_TOKEN=xoxb-…
SLACK_SIGNING_SECRET=…
# Socket Mode token (xapp-…) lets the bot run behind a NAT / on a laptop
# without exposing a public URL. Production should use HTTP mode and
# remove this var.
SLACK_APP_TOKEN=xapp-…

# Plynf proxy
PLYNF_URL=http://localhost:7430
PLYNF_API_KEY=demo

# Optional — model used when the bot needs to draft a reply itself.
# When empty, the bot just echoes shaped tool data back into the channel.
PLYNF_MODEL=gpt-4o

# Optional logging level: error | warn | info | debug
LOG_LEVEL=info
