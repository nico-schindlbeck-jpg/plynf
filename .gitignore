examples/*/reports/*.html
!examples/*/reports/.gitkeep

# Benchmark run outputs — keep the directory but ignore run JSONs.
# Commit a baseline JSON explicitly via `git add -f` if/when needed.
benchmarks/results/*.json
!benchmarks/results/.gitkeep
