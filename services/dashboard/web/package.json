{
  "name": "@plinth/dashboard-web",
  "version": "0.1.0",
  "private": true,
  "description": "Plinth dashboard SPA — Vite + Preact build pipeline. Output is consumed by services/dashboard/src/plinth_dashboard/static/dist/.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'"
  },
  "dependencies": {
    "preact": "^10.22.0",
    "preact-router": "^4.1.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.0"
  }
}
