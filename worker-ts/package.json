{
  "name": "@plinth/workflow-worker",
  "version": "0.6.1",
  "description": "Plinth durable-workflow worker for Node.js",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "plinth-workflow-worker": "./dist/cli.js"
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@plinth/sdk": "file:../sdk/typescript"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["ai", "agents", "workflow", "durable-execution", "plinth"]
}
