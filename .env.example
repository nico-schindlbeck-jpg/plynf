# Plinth — example environment file
# Copy to .env and adjust as needed; .env is gitignored.

# Where Plinth stores its SQLite + blob data
PLINTH_DATA_DIR=/tmp/plinth-data

# Service ports
PLINTH_WORKSPACE_PORT=7421
PLINTH_GATEWAY_PORT=7422
PLINTH_MOCK_MCP_PORT=7423

# Logging
PLINTH_LOG_LEVEL=INFO
PLINTH_LOG_FORMAT=console      # console | json

# API token (PoC — any non-empty string works)
PLINTH_API_TOKEN=local-dev-token

# Optional: enable real Anthropic API calls in the demo
# (otherwise the demo runs in --mode=simulation, counting tokens locally)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: alternative cache TTL for the gateway (seconds)
PLINTH_DEFAULT_CACHE_TTL=300
