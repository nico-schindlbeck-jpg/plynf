{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plinth.dev/schemas/event.schema.json",
  "title": "Plinth Observability Event",
  "description": "Canonical schema for the unified semantic event stream emitted by all Plinth services. v0.1 emits a subset of these (gateway audit only); v0.2 will fan out the full taxonomy via OTLP-compatible exporters.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "timestamp", "type", "actor", "subject"],
  "properties": {
    "id": {
      "type": "string",
      "description": "ULID-suffixed event identifier.",
      "pattern": "^evt_[A-Z0-9]{26}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "description": "Discriminator for the event family.",
      "enum": [
        "tool.invoked",
        "kv.written",
        "kv.read",
        "file.written",
        "file.read",
        "snapshot.created",
        "branch.created",
        "branch.merged",
        "workspace.created",
        "workspace.deleted",
        "agent.started",
        "agent.finished",
        "error"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "description": "Who caused the event.",
      "properties": {
        "kind": {
          "enum": ["agent", "user", "system"]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "subject": {
      "type": "object",
      "description": "What the event is about. Fields are optional and populated based on the event type.",
      "additionalProperties": false,
      "properties": {
        "workspace_id": {
          "type": "string",
          "pattern": "^ws_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "tool_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
        },
        "key": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "snapshot_id": {
          "type": "string",
          "pattern": "^snap_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "branch_id": {
          "type": "string",
          "pattern": "^br_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "agent_id": {
          "type": "string"
        }
      }
    },
    "details": {
      "type": "object",
      "description": "Free-form details specific to the event type (e.g. arguments_hash, reasoning trace).",
      "additionalProperties": true
    },
    "cost_usd": {
      "type": "number",
      "minimum": 0,
      "description": "Estimated USD cost attributed to this event."
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "description": "Token accounting where applicable (e.g. tool invocations that touched an LLM).",
      "properties": {
        "input": {
          "type": "integer",
          "minimum": 0
        },
        "output": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "description": "Set only when the event represents a failure.",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional OTLP-compatible trace context for correlating cross-service events.",
      "properties": {
        "trace_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "span_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        },
        "parent_span_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        }
      }
    }
  },
  "examples": [
    {
      "id": "evt_01HZX9V5K4M7N0Q1R2S3T4V5W6",
      "timestamp": "2026-05-05T12:00:00Z",
      "type": "tool.invoked",
      "actor": {"kind": "agent", "id": "research-bot"},
      "subject": {
        "workspace_id": "ws_01HZX9V5K4M7N0Q1R2S3T4V5W6",
        "tool_id": "web.fetch"
      },
      "details": {
        "arguments_hash": "0a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f9",
        "result_hash": "1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f9aa",
        "cached": false
      },
      "cost_usd": 0.0023,
      "duration_ms": 412
    }
  ]
}
