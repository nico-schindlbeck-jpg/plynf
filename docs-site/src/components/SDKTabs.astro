---
const tabs = [
  {
    id: "python",
    label: "Python",
    code: `from plinth import Plynf

client = Plynf(
    workspace_url="http://localhost:7421",
    gateway_url="http://localhost:7422",
    api_key="...",
)

ws = client.workspace("my-research")
ws.kv.set("topic", "renewable energy")

# Tool calls go through the gateway — cached, audited, rate-limited
result = client.invoke(
    tool_id="github.search_issues",
    args={"query": "is:open repo:plinth-dev/plinth"},
)
print(result.cached, result.cost_usd)`,
  },
  {
    id: "typescript",
    label: "TypeScript",
    code: `import { Plynf } from "@plinth/sdk";

const client = new Plynf({
  workspaceUrl: "http://localhost:7421",
  gatewayUrl: "http://localhost:7422",
  apiKey: "...",
});

const ws = await client.workspace("my-research");
await ws.kv.set("topic", "renewable energy");

// Tool calls go through the gateway — cached, audited, rate-limited
const result = await client.invoke({
  toolId: "github.search_issues",
  args: { query: "is:open repo:plinth-dev/plinth" },
});
console.log(result.cached, result.costUsd);`,
  },
  {
    id: "go",
    label: "Go",
    code: `client, _ := plinth.New(plinth.Config{
    WorkspaceURL: "http://localhost:7421",
    GatewayURL:   "http://localhost:7422",
    APIKey:       "...",
})

ws, _ := client.Workspace(ctx, "my-research")
_ = ws.KV.Set(ctx, "topic", "renewable energy")

// Tool calls go through the gateway — cached, audited, rate-limited
result, _ := client.Invoke(ctx, plinth.InvokeRequest{
    ToolID: "github.search_issues",
    Args:   map[string]any{"query": "is:open repo:plinth-dev/plinth"},
})
fmt.Println(result.Cached, result.CostUSD)`,
  },
  {
    id: "swift",
    label: "Swift",
    code: `let client = try Plynf(
    workspaceURL: URL(string: "http://localhost:7421")!,
    gatewayURL:   URL(string: "http://localhost:7422")!,
    apiKey: "..."
)

let ws = try await client.workspace(name: "my-research")
try await ws.kv.set(key: "topic", value: "renewable energy")

// Tool calls go through the gateway — cached, audited, rate-limited
let result = try await client.invoke(
    toolID: "github.search_issues",
    args: ["query": "is:open repo:plinth-dev/plinth"]
)
print(result.cached, result.costUSD)`,
  },
  {
    id: "kotlin",
    label: "Kotlin",
    code: `val client = Plynf(
    PlinthConfig(
        workspaceUrl = "http://localhost:7421",
        gatewayUrl   = "http://localhost:7422",
        apiKey       = "...",
    )
)

val ws = client.workspace("my-research")
ws.kv.set("topic", "renewable energy")

// Tool calls go through the gateway — cached, audited, rate-limited
val result = client.invoke(
    toolId = "github.search_issues",
    args   = mapOf("query" to "is:open repo:plinth-dev/plinth"),
)
println("\${result.cached} \${result.costUsd}")`,
  },
];
---

<section class="bg-rock-950 text-rock-100">
  <div class="container-narrow py-20 md:py-24">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-4 lg:sticky lg:top-24">
        <div class="text-[12px] font-bold uppercase tracking-[0.1em] text-amber-400">Same surface, five languages</div>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Pick your language. The API is identical.</h2>
        <p class="mt-5 text-rock-300 leading-relaxed">
          First-party SDKs in Python, TypeScript, Go, Swift, and Kotlin. All five are at parity for the v1 surface
          — workspace, gateway, identity, channels, and durable workflows.
        </p>
        <p class="mt-3 text-rock-400 text-sm leading-relaxed">
          ~2,867 tests passing across the seven SDK suites (Python + TS + TS-worker + Go + Swift + Kotlin + Kotlin-coroutines).
        </p>
        <a class="mt-6 inline-flex items-center gap-1 text-amber-400 font-semibold hover:text-amber-300" href="/docs/sdks">
          SDK reference
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <div class="lg:col-span-8">
        <div class="rounded-xl border border-rock-800 bg-rock-900 overflow-hidden shadow-xl shadow-rock-950/50" data-sdk-tabs>
          <div role="tablist" aria-label="SDK language" class="flex border-b border-rock-800 bg-rock-950 overflow-x-auto">
            {
              tabs.map((t, i) => (
                <button
                  type="button"
                  role="tab"
                  id={`tab-${t.id}`}
                  aria-controls={`panel-${t.id}`}
                  aria-selected={i === 0 ? "true" : "false"}
                  data-sdk-tab={t.id}
                  class={`px-4 py-3 text-[13px] font-mono uppercase tracking-wider transition-colors border-b-2 ${
                    i === 0
                      ? "border-amber-500 text-amber-400"
                      : "border-transparent text-rock-400 hover:text-rock-100"
                  }`}
                >
                  {t.label}
                </button>
              ))
            }
          </div>

          {
            tabs.map((t, i) => (
              <div
                role="tabpanel"
                id={`panel-${t.id}`}
                aria-labelledby={`tab-${t.id}`}
                data-sdk-panel={t.id}
                hidden={i !== 0}
                class="p-5 md:p-6"
              >
                <pre class="m-0 overflow-x-auto bg-transparent border-0 p-0"><code class="font-mono text-[13px] leading-relaxed text-rock-100">{t.code}</code></pre>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const STORAGE_KEY = "plinth-sdk";
  const root = document.querySelector<HTMLElement>("[data-sdk-tabs]");
  if (root) {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-sdk-tab]"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-sdk-panel]"));

    const select = (id: string) => {
      let matched = false;
      tabs.forEach((tab) => {
        const isActive = tab.dataset.sdkTab === id;
        if (isActive) matched = true;
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
        tab.classList.toggle("border-amber-500", isActive);
        tab.classList.toggle("text-amber-400", isActive);
        tab.classList.toggle("border-transparent", !isActive);
        tab.classList.toggle("text-rock-400", !isActive);
      });
      panels.forEach((p) => {
        const show = p.dataset.sdkPanel === id;
        if (show) p.removeAttribute("hidden");
        else p.setAttribute("hidden", "");
      });
      if (matched) {
        try {
          localStorage.setItem(STORAGE_KEY, id);
        } catch {}
      }
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const id = tab.dataset.sdkTab;
        if (id) select(id);
      });
      tab.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
        e.preventDefault();
        const idx = tabs.indexOf(tab);
        const next =
          e.key === "ArrowRight"
            ? tabs[(idx + 1) % tabs.length]
            : tabs[(idx - 1 + tabs.length) % tabs.length];
        next.focus();
        const id = next.dataset.sdkTab;
        if (id) select(id);
      });
    });

    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored && tabs.some((t) => t.dataset.sdkTab === stored)) {
        select(stored);
      }
    } catch {}
  }
</script>
