---
---

<section class="relative overflow-hidden bg-rock-50">
  <div class="absolute inset-0 hero-grid pointer-events-none" aria-hidden="true"></div>
  <div
    class="absolute -top-32 left-1/2 -translate-x-1/2 h-[420px] w-[1100px] rounded-full bg-amber-200/30 blur-3xl pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative container-narrow py-20 md:py-28 lg:py-32">
    <div class="mx-auto max-w-4xl text-center">
      <div
        class="mx-auto inline-flex items-center gap-2 rounded-full border border-rock-300 bg-rock-50/80 px-3 py-1 text-[12px] font-medium text-rock-700 shadow-sm animate-fade-in-up"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-amber-500"></span>
        v1.5 Tier-2 Sweep — 5 SDKs · API v1 stable · Apache 2.0
      </div>

      <div class="mt-8 mx-auto select-none text-[64px] md:text-[80px] leading-none animate-fade-in-up [animation-delay:60ms]">
        🪨
      </div>

      <h1
        class="mt-6 text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-rock-900 leading-[1.1] animate-fade-in-up [animation-delay:120ms]"
      >
        The runtime where production
        <br class="hidden md:block" />
        AI agents <span class="relative inline-block">
          <span class="relative z-10">actually work</span>
          <span
            class="absolute inset-x-1 bottom-1 h-3 md:h-4 bg-amber-300/60 -z-0 rounded-sm"
            aria-hidden="true"
          ></span>
        </span>.
      </h1>

      <p
        class="mt-6 text-lg md:text-xl leading-relaxed text-rock-600 max-w-2xl mx-auto animate-fade-in-up [animation-delay:180ms]"
      >
        A versioned workspace, tool gateway, and multi-agent channels — purpose-built for AI agents,
        not retrofitted from human UIs. <strong class="text-rock-900">71% fewer tokens</strong> on real workloads. Stable API.
        5 SDK languages.
      </p>

      <div
        class="mt-10 flex flex-col sm:flex-row gap-3 justify-center animate-fade-in-up [animation-delay:240ms]"
      >
        <a class="btn-primary" href="/docs/quickstart">
          Get started
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </a>
        <a class="btn-ghost" href="https://github.com/nico-schindlbeck-jpg/plinth" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
          View on GitHub
        </a>
      </div>

      <dl
        class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-4 text-left max-w-2xl mx-auto animate-fade-in-up [animation-delay:300ms]"
      >
        {[
          { v: "~2,867", l: "tests across 7 SDK suites" },
          { v: "5", l: "SDK languages" },
          { v: "8", l: "OAuth providers" },
          { v: "v1.5", l: "API stable, additive only" },
        ].map((s) => (
          <div class="text-center md:text-left">
            <dt class="text-[12px] uppercase tracking-wider text-rock-500 font-semibold">{s.l}</dt>
            <dd class="mt-1 text-2xl font-bold text-rock-900 tracking-tight font-mono">{s.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>
