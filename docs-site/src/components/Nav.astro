---
const path = Astro.url.pathname;
const isActive = (prefix: string) =>
  prefix === "/"
    ? path === "/"
    : path === prefix || path.startsWith(prefix + "/") || path.startsWith(prefix);

const links = [
  { label: "Docs", href: "/docs/overview" },
  { label: "Why Plinth", href: "/why" },
  { label: "Pricing", href: "/pricing" },
];
---

<header
  class="sticky top-0 z-50 w-full border-b border-rock-200/80 bg-rock-50/80 backdrop-blur-md supports-[backdrop-filter]:bg-rock-50/60"
>
  <div class="container-narrow flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Plinth home">
      <span class="text-2xl leading-none transition-transform group-hover:rotate-[-6deg]">🪨</span>
      <span class="font-bold text-[17px] text-rock-900 tracking-tight">Plinth</span>
      <span class="hidden sm:inline-block ml-2 text-[11px] font-mono uppercase tracking-wider text-rock-500 border border-rock-300 rounded px-1.5 py-0.5">
        v1.5
      </span>
    </a>
    <nav class="hidden md:flex items-center gap-1" aria-label="Main">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              isActive(l.href.startsWith("/docs") ? "/docs" : l.href)
                ? "text-rock-900 bg-rock-100"
                : "text-rock-600 hover:text-rock-900 hover:bg-rock-100"
            }`}
          >
            {l.label}
          </a>
        ))
      }
      <a
        href="https://github.com/nico-schindlbeck-jpg/plinth"
        rel="noopener noreferrer"
        target="_blank"
        class="ml-2 inline-flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-medium text-rock-600 hover:text-rock-900 hover:bg-rock-100"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
        GitHub
      </a>
    </nav>

    {/* Mobile burger */}
    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-rock-700 hover:bg-rock-100"
      aria-controls="mobile-nav"
      aria-expanded="false"
      data-mobile-nav-toggle
      aria-label="Toggle navigation"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <div id="mobile-nav" class="md:hidden border-t border-rock-200 bg-rock-50 hidden" data-mobile-nav>
    <div class="container-narrow py-3 flex flex-col gap-1">
      {
        links.map((l) => (
          <a href={l.href} class="px-3 py-2 rounded-md text-sm font-medium text-rock-700 hover:bg-rock-100">
            {l.label}
          </a>
        ))
      }
      <a
        href="https://github.com/nico-schindlbeck-jpg/plinth"
        target="_blank"
        rel="noopener noreferrer"
        class="px-3 py-2 rounded-md text-sm font-medium text-rock-700 hover:bg-rock-100"
      >
        GitHub →
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-nav-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-mobile-nav]");
  if (toggle && panel) {
    toggle.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    });
  }
</script>
