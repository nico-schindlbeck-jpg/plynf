---

<section class="bg-rock-50">
  <div class="container-narrow py-20 md:py-24">
    <div class="max-w-2xl">
      <div class="text-[12px] font-bold uppercase tracking-[0.1em] text-amber-700">What's in the box</div>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-rock-900 tracking-tight">
        Everything an agent runtime needs.
        <br />
        Nothing it doesn't.
      </h2>
      <p class="mt-4 text-rock-600 text-lg leading-relaxed">
        Six primitives, independently composable. Build the substrate first; the rest snaps in.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="card group">
            <div class="flex items-center justify-center h-10 w-10 rounded-lg bg-rock-900 text-rock-50 group-hover:bg-amber-600 transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={iconPaths[f.icon]} />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold text-rock-900 text-lg">{f.title}</h3>
            <p class="mt-1.5 text-rock-600 text-[14.5px] leading-relaxed">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
