---
const features = [
  {
    title: "Persistent Workspace",
    body: "Versioned KV + files + snapshots + branches. Agent memory survives crashes, restarts, and hand-offs. Reference state by key — stop re-reading it into every prompt.",
    icon: "workspace",
  },
  {
    title: "Tool Gateway",
    body: "One auth boundary for every MCP / REST / GraphQL tool. Caches results, enforces rate limits and cost caps, writes a tamper-evident audit chain. 8 OAuth providers shipped.",
    icon: "gateway",
  },
  {
    title: "Multi-Agent Channels",
    body: "Durable, sequenced, schema-validated message queues. Agents compose into pipelines without inheriting each other's prompt context. Bad messages route to a DLQ.",
    icon: "channels",
  },
  {
    title: "Resumable Workflows",
    body: "Lease-based recovery, checkpointed steps, Saga-style compensating actions. Crash mid-flight, restart, pick up from the last snapshot — verified end-to-end in the demo.",
    icon: "workflow",
  },
  {
    title: "Production-Ready",
    body: "JWT capability tokens (RS256 + key rotation), per-tenant quotas, GDPR export + delete, multi-tenant isolation, k8s/Helm/Terraform deployment artifacts.",
    icon: "shield",
  },
  {
    title: "Observability",
    body: "Prometheus metrics on every service, OTLP export to your collector, dashboard time-series, 26 published SLOs. Every action attributable, every cost trackable.",
    icon: "telemetry",
  },
];

const iconPaths: Record<string, string> = {
