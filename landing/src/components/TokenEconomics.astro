---
// Phase 4.3 — Side-by-side bar chart: with vs without Plynf
---

<section class="section relative" id="tokens">
  <div class="container-page" data-reveal>
    <div class="max-w-3xl">
      <p class="section-eyebrow">Token economics</p>
      <h2 class="section-title text-balance">
        <span class="text-ink-muted">23,704 tokens</span> becomes
        <br class="hidden sm:block" />
        <span class="gradient-text-accent">6,795.</span>
      </h2>
      <p class="section-subtitle">
        Same task, same model, same five sources. The difference is whether the
        agent re-reads its own past notes on every step. Real workload, fully
        reproducible.
      </p>
    </div>

    <div class="mt-16 card card-tint-pink p-8 sm:p-12 relative overflow-hidden">
      <div class="grid grid-cols-[1fr_auto_1fr] items-end gap-6 sm:gap-12">
        <!-- Without Plynf — taller, pink-to-red -->
        <div class="flex flex-col items-center text-center">
          <p class="font-mono text-2xs uppercase tracking-widest text-ink-muted">Without Plynf</p>
          <p class="mt-2 font-semibold text-ink-primary"
             style="font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1; letter-spacing: -0.04em;">
            <span class="counter-token" data-target="23704">23,704</span>
          </p>
          <p class="mt-1 text-xs font-mono uppercase tracking-widest text-[#f87171]">tokens / task</p>

          <!-- Bar -->
          <div class="mt-6 w-full max-w-[180px] relative" style="height: 260px;">
            <div
              class="bar-fill absolute bottom-0 left-1/2 -translate-x-1/2 w-full rounded-t-lg"
              style="
                height: 100%;
                background: linear-gradient(180deg, #ff8551, #ef4444);
                box-shadow: 0 0 60px rgba(255, 133, 81, 0.5), inset 0 -2px 0 rgba(0,0,0,0.3);
              "
            ></div>
            <!-- Step markers showing growth -->
            <div class="absolute inset-x-0 bottom-0 pointer-events-none" style="height:100%;">
              <div class="absolute inset-x-0 border-t border-white/10" style="bottom:20%;"></div>
              <div class="absolute inset-x-0 border-t border-white/10" style="bottom:40%;"></div>
              <div class="absolute inset-x-0 border-t border-white/10" style="bottom:60%;"></div>
              <div class="absolute inset-x-0 border-t border-white/10" style="bottom:80%;"></div>
            </div>
          </div>
          <p class="mt-3 text-xs text-ink-muted">Prompt re-reads history every step</p>
        </div>

        <!-- Center badge -->
        <div class="flex flex-col items-center self-center">
          <div
            class="inline-flex h-20 w-20 sm:h-24 sm:w-24 items-center justify-center rounded-full font-semibold"
            style="
              background: linear-gradient(135deg, var(--grad-orange), var(--grad-magenta), var(--grad-indigo));
              background-size: 200% 200%;
              animation: grad-shift 6s ease-in-out infinite;
              color: #190612;
              font-size: clamp(1.25rem, 3vw, 1.75rem);
              letter-spacing: -0.04em;
              box-shadow: 0 0 40px rgba(255, 133, 81, 0.45), inset 0 1px 0 rgba(255,255,255,0.4);
            "
          >
            &minus;71%
          </div>
          <p class="mt-3 font-mono text-2xs uppercase tracking-widest text-ink-secondary text-center">
            tokens
            <br/>removed
          </p>
        </div>

        <!-- With Plynf — shorter, cyan-to-indigo -->
        <div class="flex flex-col items-center text-center">
          <p class="font-mono text-2xs uppercase tracking-widest" style="color: var(--grad-indigo);">With Plynf</p>
          <p class="mt-2 font-semibold text-ink-primary"
             style="font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1; letter-spacing: -0.04em;">
            <span class="counter-token" data-target="6795">6,795</span>
          </p>
          <p class="mt-1 text-xs font-mono uppercase tracking-widest" style="color: var(--grad-indigo);">tokens / task</p>

          <div class="mt-6 w-full max-w-[180px] relative" style="height: 260px;">
            <div
              class="bar-fill absolute bottom-0 left-1/2 -translate-x-1/2 w-full rounded-t-lg"
              style="
                height: 28.7%;
                background: linear-gradient(180deg, #6366f1, #6366f1);
                box-shadow: 0 0 50px rgba(99, 102, 241, 0.45), inset 0 -2px 0 rgba(0,0,0,0.3);
                transition-delay: 0.3s;
              "
            ></div>
          </div>
          <p class="mt-3 text-xs text-ink-muted">State lives in the workspace</p>
        </div>
      </div>

      <!-- Caption row -->
      <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm pt-6 border-t border-border">
        <div>
          <p class="text-2xs font-mono uppercase tracking-widest text-ink-muted">Task</p>
          <p class="mt-1.5 text-ink-secondary">5-source research summary</p>
        </div>
        <div>
          <p class="text-2xs font-mono uppercase tracking-widest text-ink-muted">Model</p>
          <p class="mt-1.5 text-ink-secondary">Claude · 10 reasoning steps</p>
        </div>
        <div>
          <p class="text-2xs font-mono uppercase tracking-widest" style="color: var(--grad-indigo);">Reproducible</p>
          <p class="mt-1.5 text-ink-secondary">examples/token-bench in repo</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var prefersReduce = window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    var counters = document.querySelectorAll(".counter-token");
    if (!counters.length) return;

    function animate(el) {
      var target = parseInt(el.getAttribute("data-target") || "0", 10);
      if (prefersReduce || !target) {
        el.textContent = target.toLocaleString("en-US");
        return;
      }
      var duration = 1600;
      var start = performance.now();
      function frame(now) {
        var t = Math.min(1, (now - start) / duration);
        var eased = t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
        var v = Math.round(target * eased);
        el.textContent = v.toLocaleString("en-US");
        if (t < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    if (typeof IntersectionObserver === "undefined") {
      counters.forEach(animate);
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animate(entry.target);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });
    counters.forEach(function (c) { io.observe(c); });
  })();
</script>
