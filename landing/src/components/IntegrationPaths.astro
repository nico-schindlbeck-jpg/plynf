---
const paths = [
  {
    name: "Drop-in LLM Proxy",
    target: "OpenAI · Anthropic · Gemini · Azure · Ollama · vLLM",
    setup: "Change `base_url`. Keep your client code. One front-door speaks all three API dialects.",
    snippet: `client = OpenAI(\n  api_key="sk-…",\n  base_url="https://app.plynf.com/v1"\n)`,
    time: "1 min",
  },
  {
    name: "MCP Server",
    target: "Anthropic Claude API · MCP-native clients",
    setup: "Register Plynf as an MCP server in your client config.",
    snippet: `mcp_servers=[{\n  "url": "https://app.plynf.com/mcp/salesforce"\n}]`,
    time: "2 min",
  },
  {
    name: "Native SDK · 5 languages",
    target: "Python · TypeScript · Go · Swift · Kotlin",
    setup: "Wrap your existing tools — LangChain, LlamaIndex, CrewAI, AutoGen.",
    snippet: `from plynf.langchain import wrap_tools\ntools = wrap_tools([sf_tool, slack_tool])`,
    time: "5 min",
  },
  {
    name: "No-Code Node",
    target: "n8n · Zapier · Make.com · Copilot Studio",
    setup: "Install the Plynf node from the marketplace. Drag-and-drop.",
    snippet: "// n8n workflow → Plynf · Salesforce → LLM",
    time: "3 min",
  },
  {
    name: "Chat & Helpdesk Bots",
    target: "Slack · Teams · Discord · Salesforce Agentforce",
    setup: "Deploy a ready-made bot. One-click deploy buttons or “Add to Slack” OAuth.",
    snippet: "@Plynf what's the status of order #12345?",
    time: "3 min",
  },
  {
    name: "REST / Webhook",
    target: "Custom Python / Node agents · Bedrock Lambda",
    setup: "POST tool calls. Get shaped responses back.",
    snippet: `curl -X POST app.plynf.com/v1/tools/get_order/invoke \\\n  -d '{"order_id":"12345"}'`,
    time: "10 min",
  },
];
---

<section class="section" id="integrations">
  <div class="container-page" data-reveal>
    <div class="max-w-3xl">
      <p class="section-eyebrow">Six ways in. One engine.</p>
      <h2 class="section-title text-balance">
        Plynf is not bound to one agent framework.
        <span class="text-ink-muted">Pick the integration that fits your stack.</span>
      </h2>
      <p class="mt-6 text-ink-secondary text-lg leading-relaxed">
        The optimization layer underneath is identical — same policies,
        same caching, same audit log — whether you wire Plynf in as a
        drop-in LLM proxy (OpenAI, Anthropic and Gemini dialects), an MCP
        server, a native SDK in five languages, a no-code node, a chat bot,
        or a webhook endpoint.
      </p>
      <p class="mt-4">
        <a href="/install" class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:underline underline-offset-4">
          Browse every install path, ranked by effort
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {paths.map((p) => (
        <div class="card p-6 sm:p-7 relative overflow-hidden h-full">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="text-base font-semibold tracking-tight text-ink-primary">
                {p.name}
              </h3>
              <p class="mt-1 text-2xs font-mono uppercase tracking-widest text-ink-muted">
                {p.target}
              </p>
            </div>
            <span class="rounded-full border border-accent/30 bg-accent/5 px-2.5 py-1 text-2xs font-mono text-accent">
              {p.time}
            </span>
          </div>
          <p class="mt-4 text-sm text-ink-secondary leading-relaxed">{p.setup}</p>
          <pre class="mt-4 rounded-md border border-border bg-bg-2/40 p-3 font-mono text-2xs text-ink-secondary leading-relaxed overflow-x-auto"><code>{p.snippet}</code></pre>
        </div>
      ))}
    </div>
  </div>
</section>
