---
// Phase 4.1 — Horizontal step-by-step pipeline
// Agent emits intent → Workspace receives state → Gateway routes → Tools execute
---

<section class="section relative overflow-hidden" id="flow">
  <div class="container-page" data-reveal>
    <div class="max-w-3xl">
      <p class="section-eyebrow">The flow</p>
      <h2 class="section-title text-balance">
        How an agent
        <span class="gradient-text-accent">flows through Plinth.</span>
      </h2>
      <p class="section-subtitle">
        Four stages, one call. The runtime carries the state so your prompt
        stays focused on the next decision, not the last ten.
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Diagram -->
      <svg
        viewBox="0 0 1200 280"
        role="img"
        aria-label="Pipeline diagram: agent emits intent, workspace receives state, gateway routes tools, tools execute"
        class="w-full h-auto"
      >
        <defs>
          <linearGradient id="flow-orange-warm" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="#ff8551"/>
            <stop offset="100%" stop-color="#ff8551"/>
          </linearGradient>
          <linearGradient id="flow-orange-magenta" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="#ff8551"/>
            <stop offset="100%" stop-color="#d946ef"/>
          </linearGradient>
          <linearGradient id="flow-magenta-indigo" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="#d946ef"/>
            <stop offset="100%" stop-color="#6366f1"/>
          </linearGradient>

          <radialGradient id="node-orange" cx="0.5" cy="0.45" r="0.6">
            <stop offset="0%"  stop-color="#ff8551" stop-opacity="1"/>
            <stop offset="100%" stop-color="#ff8551" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="node-magenta" cx="0.5" cy="0.45" r="0.6">
            <stop offset="0%"  stop-color="#d946ef" stop-opacity="1"/>
            <stop offset="100%" stop-color="#d946ef" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="node-indigo" cx="0.5" cy="0.45" r="0.6">
            <stop offset="0%"  stop-color="#6366f1" stop-opacity="1"/>
            <stop offset="100%" stop-color="#6366f1" stop-opacity="0"/>
          </radialGradient>

          <filter id="flow-glow">
            <feGaussianBlur stdDeviation="10"/>
          </filter>
        </defs>

        <!-- Curved connector lines (pink to indigo) -->
        <g fill="none" stroke-width="2" stroke-linecap="round">
          <path d="M 220 140 C 290 140, 290 140, 360 140" stroke="url(#flow-orange-warm)"    class="pulse-line"/>
          <path d="M 510 140 C 580 140, 580 140, 650 140" stroke="url(#flow-orange-magenta)" class="pulse-line" style="animation-delay:-0.7s"/>
          <path d="M 800 140 C 870 140, 870 140, 940 140" stroke="url(#flow-magenta-indigo)" class="pulse-line" style="animation-delay:-1.4s"/>
        </g>

        <!-- Stage 1 — Agent emits intent (orange) -->
        <g class="diagram-stage" data-stage="1" transform="translate(70 60)">
          <!-- Glow halo -->
          <circle cx="75" cy="80" r="90" fill="url(#node-orange)" opacity="0.45" filter="url(#flow-glow)"/>
          <!-- Bubble icon (speech) -->
          <circle cx="75" cy="80" r="40" fill="#08070d" stroke="#ff8551" stroke-width="1.5"/>
          <path d="M55 75 q0 -8 8 -8 h24 q8 0 8 8 v8 q0 8 -8 8 h-14 l-8 8 v-8 h-2 q-8 0 -8 -8 z"
                fill="#ff8551" opacity="0.95"/>
          <!-- Label -->
          <text x="75" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#6e6a8a" letter-spacing="1.5">STAGE 01</text>
          <text x="75" y="184" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="600" fill="#f8f7ff">Agent emits intent</text>
          <text x="75" y="206" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#b9b5d4">Your loop calls one SDK method.</text>
        </g>

        <!-- Stage 2 — Workspace (magenta) -->
        <g class="diagram-stage" data-stage="2" transform="translate(360 60)">
          <circle cx="75" cy="80" r="90" fill="url(#node-magenta)" opacity="0.45" filter="url(#flow-glow)"/>
          <circle cx="75" cy="80" r="40" fill="#08070d" stroke="#d946ef" stroke-width="1.5"/>
          <!-- Stack icon -->
          <g stroke="#d946ef" stroke-width="2" fill="none" stroke-linejoin="round">
            <rect x="56" y="62" width="38" height="9" rx="2" fill="#d946ef" fill-opacity="0.18"/>
            <rect x="56" y="74" width="38" height="9" rx="2" fill="#d946ef" fill-opacity="0.32"/>
            <rect x="56" y="86" width="38" height="9" rx="2" fill="#d946ef" fill-opacity="0.5"/>
          </g>
          <text x="75" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#6e6a8a" letter-spacing="1.5">STAGE 02</text>
          <text x="75" y="184" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="600" fill="#f8f7ff">Workspace receives state</text>
          <text x="75" y="206" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#b9b5d4">Versioned KV, files, snapshots.</text>
        </g>

        <!-- Stage 3 — Gateway (magenta) -->
        <g class="diagram-stage" data-stage="3" transform="translate(650 60)">
          <circle cx="75" cy="80" r="90" fill="url(#node-magenta)" opacity="0.45" filter="url(#flow-glow)"/>
          <circle cx="75" cy="80" r="40" fill="#08070d" stroke="#d946ef" stroke-width="1.5"/>
          <!-- Hub icon -->
          <g stroke="#d946ef" stroke-width="2" stroke-linecap="round" fill="none">
            <circle cx="75" cy="80" r="6" fill="#d946ef"/>
            <line x1="75" y1="64" x2="75" y2="58"/>
            <line x1="75" y1="96" x2="75" y2="102"/>
            <line x1="59" y1="80" x2="53" y2="80"/>
            <line x1="91" y1="80" x2="97" y2="80"/>
            <line x1="63" y1="68" x2="58" y2="63"/>
            <line x1="87" y1="92" x2="92" y2="97"/>
            <line x1="63" y1="92" x2="58" y2="97"/>
            <line x1="87" y1="68" x2="92" y2="63"/>
          </g>
          <text x="75" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#6e6a8a" letter-spacing="1.5">STAGE 03</text>
          <text x="75" y="184" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="600" fill="#f8f7ff">Gateway routes tools</text>
          <text x="75" y="206" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#b9b5d4">OAuth, cache, audit, cost caps.</text>
        </g>

        <!-- Stage 4 — Tools (indigo) -->
        <g class="diagram-stage" data-stage="4" transform="translate(940 60)">
          <circle cx="75" cy="80" r="90" fill="url(#node-indigo)" opacity="0.45" filter="url(#flow-glow)"/>
          <circle cx="75" cy="80" r="40" fill="#08070d" stroke="#6366f1" stroke-width="1.5"/>
          <!-- Fan-out: 8 dots radiating -->
          <g fill="#6366f1">
            <circle cx="75" cy="58" r="3.5"/>
            <circle cx="91" cy="64" r="3.5"/>
            <circle cx="97" cy="80" r="3.5"/>
            <circle cx="91" cy="96" r="3.5"/>
            <circle cx="75" cy="102" r="3.5"/>
            <circle cx="59" cy="96" r="3.5"/>
            <circle cx="53" cy="80" r="3.5"/>
            <circle cx="59" cy="64" r="3.5"/>
            <circle cx="75" cy="80" r="6" fill="#6366f1"/>
          </g>
          <text x="75" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#6e6a8a" letter-spacing="1.5">STAGE 04</text>
          <text x="75" y="184" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="600" fill="#f8f7ff">Tools execute</text>
          <text x="75" y="206" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" fill="#b9b5d4">Eight providers. Streaming results.</text>
        </g>
      </svg>
    </div>
  </div>
</section>
