---
const problems = [
  {
    title: "Token explosion",
    body:
      "Every step drags the entire conversation history. By step ten, you're paying ~10× to re-read your own past notes.",
  },
  {
    title: "No recovery",
    body:
      "Crash mid-task and the work is lost. Hand-offs to other agents become walls of pasted text.",
  },
  {
    title: "No audit",
    body:
      "Five tools, five bespoke integrations, five places where rate limits, costs, and security review go to die.",
  },
];

const solutions = [
  {
    title: "State lives in the workspace",
    body:
      "Facts under keys, files on disk, snapshots and branches. Prompts stay small and focused — token bill goes linear.",
  },
  {
    title: "Resume from the last checkpoint",
    body:
      "Lease-based workers pick up where the crashed one stopped. No work lost. Verified by a runnable demo.",
  },
  {
    title: "One gateway, full audit",
    body:
      "Every tool call: cached, rate-limited, cost-capped, OAuth-handled, audit-logged. One coherent surface.",
  },
];
---

<section class="section" id="why">
  <div class="container-page" data-reveal>
    <div class="max-w-3xl">
      <p class="section-eyebrow">The shift</p>
      <h2 class="section-title text-balance">
        Agents today are wrapped around
        <span class="text-ink-muted">interfaces built for humans.</span>
        <br class="hidden sm:block" />
        Plinth makes the agent the first-class user.
      </h2>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-2 lg:gap-8">
      <!-- Problem column -->
      <div class="card p-8 sm:p-10 relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#ef4444]/30 to-transparent"></div>
        <div class="flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-[#ef4444]"></span>
          <p class="text-xs font-mono uppercase tracking-widest text-[#f87171]">
            Without Plinth
          </p>
        </div>
        <h3 class="mt-4 text-xl font-semibold tracking-tight text-ink-primary">
          Quadratic costs. Lost work. Bespoke integrations.
        </h3>
        <ul class="mt-8 space-y-6">
          {
            problems.map((p) => (
              <li>
                <div class="flex items-start gap-3">
                  <svg class="mt-1 h-4 w-4 flex-none text-[#f87171]/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                  </svg>
                  <div>
                    <p class="font-medium text-ink-primary">{p.title}</p>
                    <p class="mt-1 text-sm leading-relaxed text-ink-secondary">{p.body}</p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Solution column -->
      <div class="card p-8 sm:p-10 relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
        <div class="flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-accent" style="box-shadow:0 0 8px var(--accent-glow)"></span>
          <p class="text-xs font-mono uppercase tracking-widest text-accent">
            With Plinth
          </p>
        </div>
        <h3 class="mt-4 text-xl font-semibold tracking-tight text-ink-primary">
          Linear costs. Resumable work. One coherent surface.
        </h3>
        <ul class="mt-8 space-y-6">
          {
            solutions.map((s) => (
              <li>
                <div class="flex items-start gap-3">
                  <svg class="mt-1 h-4 w-4 flex-none text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                  </svg>
                  <div>
                    <p class="font-medium text-ink-primary">{s.title}</p>
                    <p class="mt-1 text-sm leading-relaxed text-ink-secondary">{s.body}</p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
