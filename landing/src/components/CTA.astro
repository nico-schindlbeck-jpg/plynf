---
const installCommand = "curl -fsSL https://plynf.com/install.sh | sh";
---

<section class="section relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-grid"></div>
    <!-- Vivid radial gradient halo, anchored bottom-center for emotional weight -->
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse 60% 50% at 30% 30%, rgba(255, 133, 81, 0.18), transparent 60%),
      radial-gradient(ellipse 60% 50% at 70% 60%, rgba(99, 102, 241, 0.16), transparent 60%),
      radial-gradient(ellipse 60% 50% at 50% 90%, rgba(217, 70, 239, 0.16), transparent 65%);"></div>
  </div>

  <div class="container-narrow text-center" data-reveal>
    <p class="section-eyebrow">Ready when you are</p>
    <h2 class="mt-3 font-bold text-balance" style="font-size: clamp(2.5rem, 7vw, 5rem); line-height: 0.98; letter-spacing: -0.055em;">
      <span class="gradient-text">Build the agent.</span><br/>
      <span class="gradient-text-accent">We'll handle the substrate.</span>
    </h2>
    <p class="mt-5 text-ink-secondary text-base sm:text-lg max-w-xl mx-auto">
      One command. Local in 30 seconds. Production-ready when you are.
    </p>

    <div class="mt-10 mx-auto max-w-xl">
      <div class="card overflow-hidden">
        <div class="flex items-center justify-between border-b border-border px-4 py-2.5 bg-bg-2/40">
          <div class="flex items-center gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]/60"></span>
          </div>
          <button
            type="button"
            id="copy-cta"
            class="flex items-center gap-1.5 rounded-md px-2 py-1 text-2xs font-mono text-ink-secondary hover:text-ink-primary hover:bg-bg-3 transition-colors"
            aria-label="Copy install command"
            data-copy={installCommand}
          >
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="copy-label">COPY</span>
          </button>
        </div>
        <div class="px-5 py-4 text-left">
          <pre class="font-mono text-sm text-ink-primary overflow-x-auto"><span class="text-accent">$</span> {installCommand}</pre>
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="https://github.com/nico-schindlbeck-jpg/plinth" rel="noopener" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.34-1.75-1.34-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.83 2.81 1.3 3.5.99.11-.77.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.19.69.8.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        Star on GitHub
      </a>
      <a href="https://docs.plynf.com" class="btn btn-secondary">
        Read the docs
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var btn = document.getElementById("copy-cta");
    if (!btn) return;
    var label = btn.querySelector(".copy-label");
    btn.addEventListener("click", async function () {
      try {
        await navigator.clipboard.writeText(btn.getAttribute("data-copy") || "");
        if (label) {
          var prev = label.textContent;
          label.textContent = "COPIED";
          setTimeout(function () { label.textContent = prev; }, 1500);
        }
      } catch (_) {}
    });
  })();
</script>
