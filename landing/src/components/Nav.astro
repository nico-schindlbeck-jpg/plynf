---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { href: "/#features", label: "Features" },
  { href: "/#how", label: "How it works" },
  { href: "/pricing", label: "Pricing" },
  { href: "/manifesto", label: "Manifesto" },
  { href: "/about", label: "About" },
];
---

<header class="sticky top-0 z-40 backdrop-blur-xl">
  <div class="absolute inset-0 -z-10 bg-bg-0/70 border-b border-border"></div>
  <nav class="container-page flex h-14 items-center justify-between">
    <a href="/" class="group flex items-center gap-2.5" aria-label="Plinth home">
      <span class="relative flex h-7 w-7 items-center justify-center rounded-lg bg-bg-2 border border-border overflow-hidden">
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <defs>
            <linearGradient id="nav-rock" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#ff8551" />
              <stop offset="50%" stop-color="#d946ef" />
              <stop offset="100%" stop-color="#6366f1" />
            </linearGradient>
          </defs>
          <path
            d="M5 17 L8 9 L12 6 L17 6 L20 11 L20 17 Z"
            fill="url(#nav-rock)"
            stroke="#1d1f29"
            stroke-width="0.6"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="font-semibold tracking-tight text-ink-primary text-[15px]">
        Plinth
      </span>
      <span class="hidden sm:inline-block font-mono text-2xs text-ink-muted tracking-wider">
        v1.5
      </span>
    </a>

    <div class="hidden md:flex items-center gap-7">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-ink-secondary hover:text-ink-primary transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <a
        href="https://docs.plinth.dev"
        class="hidden sm:inline-flex btn btn-ghost"
      >
        Docs
      </a>
      <ThemeToggle />
      <a
        href="https://github.com/nico-schindlbeck-jpg/plinth"
        rel="noopener"
        class="hidden sm:inline-flex btn btn-secondary"
        aria-label="View Plinth on GitHub"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.34-1.75-1.34-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.83 2.81 1.3 3.5.99.11-.77.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.19.69.8.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span>Star</span>
      </a>
      <a href="/#install" class="btn btn-primary">Get started</a>
    </div>
  </nav>
</header>
