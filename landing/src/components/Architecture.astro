---
const oauthTools = [
  "GitHub",
  "Slack",
  "Linear",
  "Notion",
  "Google",
  "Atlassian",
  "Salesforce",
  "Asana",
];
---

<section class="section relative" id="architecture">
  <div class="container-page" data-reveal>
    <div class="max-w-3xl">
      <p class="section-eyebrow">Architecture</p>
      <h2 class="section-title text-balance">
        A single coherent surface,
        <span class="text-ink-muted">composed from independent services.</span>
      </h2>
      <p class="section-subtitle">
        Each service runs as its own process. Replace, scale, or harden any
        one of them independently. No hidden coupling. No magic.
      </p>
    </div>

    <div class="mt-14 card p-6 sm:p-10 relative overflow-hidden">
      <!-- Animated diagram -->
      <svg
        viewBox="0 0 1100 480"
        role="img"
        aria-label="Plinth architecture: agent on the left talks to Workspace, Gateway, and Identity services in the middle, which in turn fan out to 8 external OAuth tools on the right."
        class="w-full h-auto"
      >
        <defs>
          <linearGradient id="arch-grad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#ff7849" stop-opacity="0.7"/>
            <stop offset="100%" stop-color="#ff7849" stop-opacity="0.1"/>
          </linearGradient>
          <linearGradient id="card-stroke" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(255,255,255,0.12)"/>
            <stop offset="100%" stop-color="rgba(255,255,255,0.04)"/>
          </linearGradient>
          <linearGradient id="card-fill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(255,255,255,0.04)"/>
            <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
          </linearGradient>
          <filter id="soft-glow">
            <feGaussianBlur stdDeviation="8" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <!-- ===== Agent (left) ===== -->
        <g transform="translate(40 180)">
          <rect width="190" height="120" rx="14" fill="url(#card-fill)" stroke="url(#card-stroke)"/>
          <text x="20" y="34" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#6b6f80" letter-spacing="1.5" style="text-transform:uppercase;">AGENT</text>
          <text x="20" y="68" font-family="Inter, sans-serif" font-size="20" font-weight="600" fill="#f4f5f8">Your loop</text>
          <text x="20" y="92" font-family="Inter, sans-serif" font-size="13" fill="#a3a7b8">Python · TS · Go</text>
          <text x="20" y="108" font-family="Inter, sans-serif" font-size="13" fill="#a3a7b8">Swift · Kotlin</text>
        </g>

        <!-- ===== Plinth core (center) ===== -->
        <g transform="translate(380 80)">
          <!-- container -->
          <rect width="320" height="320" rx="18" fill="rgba(255,255,255,0.015)" stroke="rgba(255,120,73,0.18)"/>
          <text x="20" y="30" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#ff7849" letter-spacing="1.5" style="text-transform:uppercase;">PLINTH</text>

          <!-- Workspace -->
          <g transform="translate(20 50)">
            <rect width="280" height="76" rx="12" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)"/>
            <text x="20" y="32" font-family="Inter, sans-serif" font-size="15" font-weight="600" fill="#f4f5f8">Workspace</text>
            <text x="20" y="56" font-family="Inter, sans-serif" font-size="12" fill="#a3a7b8">KV · Files · Snapshots · Branches</text>
            <rect x="240" y="20" width="22" height="22" rx="6" fill="rgba(255,120,73,0.15)" stroke="rgba(255,120,73,0.4)"/>
            <text x="244" y="35" font-family="JetBrains Mono, monospace" font-size="10" fill="#ff7849">:21</text>
          </g>

          <!-- Gateway -->
          <g transform="translate(20 142)">
            <rect width="280" height="76" rx="12" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)"/>
            <text x="20" y="32" font-family="Inter, sans-serif" font-size="15" font-weight="600" fill="#f4f5f8">Tool Gateway</text>
            <text x="20" y="56" font-family="Inter, sans-serif" font-size="12" fill="#a3a7b8">Cache · Audit · OAuth · Cost-caps</text>
            <rect x="240" y="20" width="22" height="22" rx="6" fill="rgba(255,120,73,0.15)" stroke="rgba(255,120,73,0.4)"/>
            <text x="244" y="35" font-family="JetBrains Mono, monospace" font-size="10" fill="#ff7849">:22</text>
          </g>

          <!-- Identity -->
          <g transform="translate(20 234)">
            <rect width="280" height="66" rx="12" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)"/>
            <text x="20" y="32" font-family="Inter, sans-serif" font-size="15" font-weight="600" fill="#f4f5f8">Identity</text>
            <text x="20" y="52" font-family="Inter, sans-serif" font-size="12" fill="#a3a7b8">JWT · Tenants · RS256 · JWKS</text>
            <rect x="240" y="20" width="22" height="22" rx="6" fill="rgba(255,120,73,0.15)" stroke="rgba(255,120,73,0.4)"/>
            <text x="244" y="35" font-family="JetBrains Mono, monospace" font-size="10" fill="#ff7849">:25</text>
          </g>
        </g>

        <!-- ===== Lines: agent → plinth ===== -->
        <g fill="none" stroke="url(#arch-grad)" stroke-width="1.5">
          <path d="M230 220 C 290 220, 340 100, 380 100" class="pulse-line"/>
          <path d="M230 240 C 290 240, 340 195, 380 195" class="pulse-line" style="animation-delay:-0.7s"/>
          <path d="M230 260 C 290 260, 340 290, 380 290" class="pulse-line" style="animation-delay:-1.4s"/>
        </g>

        <!-- ===== Tools (right) ===== -->
        {
          oauthTools.map((tool, i) => {
            const col = i % 2;
            const row = Math.floor(i / 2);
            const x = 780 + col * 145;
            const y = 88 + row * 76;
            return (
              <g transform={`translate(${x} ${y})`}>
                <rect width="135" height="58" rx="10" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.08)"/>
                <circle cx="18" cy="29" r="6" fill="rgba(255,120,73,0.25)" stroke="rgba(255,120,73,0.5)"/>
                <text x="34" y="26" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#f4f5f8">{tool}</text>
                <text x="34" y="42" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b6f80" letter-spacing="1">OAUTH</text>
              </g>
            );
          })
        }

        <!-- ===== Lines: plinth → tools ===== -->
        <g fill="none" stroke="url(#arch-grad)" stroke-width="1" stroke-opacity="0.6">
          <path d="M700 180 C 740 180, 760 117, 780 117" class="pulse-line" style="animation-delay:-0.2s"/>
          <path d="M700 195 C 740 195, 760 193, 780 193" class="pulse-line" style="animation-delay:-0.5s"/>
          <path d="M700 210 C 740 210, 760 269, 780 269" class="pulse-line" style="animation-delay:-0.9s"/>
          <path d="M700 225 C 740 225, 760 345, 780 345" class="pulse-line" style="animation-delay:-1.3s"/>
        </g>

        <!-- annotations -->
        <g font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6f80" letter-spacing="1" style="text-transform:uppercase;">
          <text x="244" y="180">SDK CALL</text>
          <text x="720" y="78">MCP / REST</text>
        </g>
      </svg>

      <!-- Caption -->
      <div class="mt-6 grid sm:grid-cols-3 gap-4 text-sm">
        <div>
          <p class="text-2xs font-mono uppercase tracking-widest text-ink-muted">Agent side</p>
          <p class="mt-1.5 text-ink-secondary">SDK in 5 languages. One call, no glue code.</p>
        </div>
        <div>
          <p class="text-2xs font-mono uppercase tracking-widest text-accent">Plinth runtime</p>
          <p class="mt-1.5 text-ink-secondary">Workspace + Gateway + Identity. All replaceable.</p>
        </div>
        <div>
          <p class="text-2xs font-mono uppercase tracking-widest text-ink-muted">Tools side</p>
          <p class="mt-1.5 text-ink-secondary">8 OAuth providers built-in. MCP for the rest.</p>
        </div>
      </div>
    </div>
  </div>
</section>
