---
const installCommand = "curl -fsSL https://plynf.com/install.sh | sh";
---

<section class="relative overflow-hidden">
  <!-- Layered backgrounds with parallax. Grid layer scrolls slower for depth. -->
  <div class="bg-grid" data-hero-parallax></div>
  <div class="bg-hero-glow"></div>

  <div class="container-page relative z-10 pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="flex flex-col items-center text-center">
      <a href="https://github.com/nico-schindlbeck-jpg/plinth/releases" class="eyebrow group transition-colors hover:border-border-strong">
        <span class="eyebrow-dot"></span>
        <span>v1.5 · Production-ready agent runtime</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-ink-muted transition-transform group-hover:translate-x-0.5">
          <path d="M9 5l7 7-7 7" />
        </svg>
      </a>

      <h1 class="mt-8 max-w-4xl text-balance font-semibold text-ink-primary"
        style="font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1.04; letter-spacing: -0.045em;">
        <span class="gradient-text">The runtime where</span>
        <br />
        <span class="gradient-text">production AI agents</span>
        <br />
        <span class="gradient-text-accent">actually work.</span>
      </h1>

      <p class="mt-7 max-w-2xl text-balance text-ink-secondary text-lg leading-relaxed">
        A versioned workspace, a tool gateway, and multi-agent channels.
        Designed for AI agents. Not retrofitted from human UIs.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3" id="install">
        <a href="#install-block" class="btn btn-primary">
          Get started
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <a href="https://github.com/nico-schindlbeck-jpg/plinth" rel="noopener" class="btn btn-secondary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.34-1.75-1.34-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.83 2.81 1.3 3.5.99.11-.77.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.19.69.8.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
          <span class="hidden sm:inline-flex items-center gap-1 ml-1 text-ink-muted font-mono text-xs">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .587l3.668 7.568L24 9.423l-6 5.847 1.417 8.255L12 19.771l-7.417 3.754L6 15.27 0 9.423l8.332-1.268z"/>
            </svg>
            2.4k
          </span>
        </a>
      </div>

      <!-- Install command block -->
      <div id="install-block" class="mt-12 w-full max-w-2xl" data-reveal>
        <div class="relative group">
          <div class="card overflow-hidden">
            <div class="flex items-center justify-between border-b border-border px-4 py-2.5 bg-bg-2/40">
              <div class="flex items-center gap-1.5">
                <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]/60"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]/60"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]/60"></span>
              </div>
              <span class="font-mono text-2xs text-ink-muted uppercase tracking-widest">
                install · macOS · linux
              </span>
              <button
                type="button"
                id="copy-install"
                class="flex items-center gap-1.5 rounded-md px-2 py-1 text-2xs font-mono text-ink-secondary hover:text-ink-primary hover:bg-bg-3 transition-colors"
                aria-label="Copy install command"
                data-copy={installCommand}
              >
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span class="copy-label">COPY</span>
              </button>
            </div>
            <div class="px-5 py-4 text-left">
              <pre class="font-mono text-sm text-ink-primary overflow-x-auto"><span class="text-accent">$</span> <span>{installCommand}</span></pre>
            </div>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-2xs font-mono uppercase tracking-widest text-ink-muted">
          <span class="flex items-center gap-1.5">
            <span class="text-accent">71%</span> fewer tokens
          </span>
          <span class="text-border-strong">·</span>
          <span class="flex items-center gap-1.5">
            <span class="text-ink-secondary">2,867</span> tests
          </span>
          <span class="text-border-strong">·</span>
          <span class="flex items-center gap-1.5">
            <span class="text-ink-secondary">5</span> SDKs
          </span>
          <span class="text-border-strong">·</span>
          <span class="text-ink-secondary">Apache 2.0</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-b from-transparent to-bg-0 z-10 pointer-events-none"></div>
</section>

<script is:inline>
  (function () {
    var btn = document.getElementById("copy-install");
    if (!btn) return;
    var label = btn.querySelector(".copy-label");
    btn.addEventListener("click", async function () {
      try {
        await navigator.clipboard.writeText(btn.getAttribute("data-copy") || "");
        if (label) {
          var prev = label.textContent;
          label.textContent = "COPIED";
          setTimeout(function () { label.textContent = prev; }, 1500);
        }
      } catch (_) {}
    });
  })();
</script>
