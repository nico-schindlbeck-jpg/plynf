---
const features = [
  {
    title: "Persistent workspace",
    desc: "KV + files + snapshots + branches. Versioned. Crash-safe. The agent's memory survives everything.",
    icon: "workspace",
  },
  {
    title: "Tool gateway",
    desc: "Single boundary for every external tool. Caching, audit, OAuth, cost-caps. All built-in.",
    icon: "gateway",
  },
  {
    title: "Multi-agent channels",
    desc: "Durable typed message queues. Multi-agent pipelines without prompt-history sprawl.",
    icon: "channels",
  },
  {
    title: "Resumable workflows",
    desc: "Worker pool with lease-based recovery. Crash mid-flight, pick up where you left off.",
    icon: "workflow",
  },
  {
    title: "Production safety",
    desc: "JWT, multi-tenant, GDPR, rate limits, tamper-evident audit, threat model.",
    icon: "safety",
  },
  {
    title: "8 OAuth providers",
    desc: "GitHub, Slack, Linear, Notion, Google Workspace, Atlassian, Salesforce, Asana.",
    icon: "oauth",
  },
];
---

<section class="section relative" id="features">
  <div class="bg-grid-dense"></div>
  <div class="container-page relative z-10" data-reveal>
    <div class="max-w-3xl">
      <p class="section-eyebrow">Capabilities</p>
      <h2 class="section-title text-balance">
        Everything your agent needs.
        <br class="hidden sm:block" />
        <span class="text-ink-muted">Nothing it doesn't.</span>
      </h2>
      <p class="section-subtitle">
        Six primitives, designed together. Each one removes a category of
        plumbing you'd otherwise have to build, deploy, and maintain yourself.
      </p>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 sm:gap-5">
      {
        features.map((f) => (
          <article class="card card-hover glow-card p-7 group relative overflow-hidden">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-bg-2 border border-border text-accent">
              {f.icon === "workspace" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                  <path d="M3 9h18M9 21V9"></path>
                </svg>
              )}
              {f.icon === "gateway" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="3"></circle>
                  <path d="M12 3v6M12 15v6M3 12h6M15 12h6M5.6 5.6l4.2 4.2M14.2 14.2l4.2 4.2M5.6 18.4l4.2-4.2M14.2 9.8l4.2-4.2"></path>
                </svg>
              )}
              {f.icon === "channels" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                </svg>
              )}
              {f.icon === "workflow" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="23 4 23 10 17 10"></polyline>
                  <polyline points="1 20 1 14 7 14"></polyline>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
              )}
              {f.icon === "safety" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <path d="M9 12l2 2 4-4"></path>
                </svg>
              )}
              {f.icon === "oauth" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="11" width="18" height="11" rx="2"></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
              )}
            </div>
            <h3 class="mt-6 text-lg font-semibold tracking-tight text-ink-primary">
              {f.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-secondary">
              {f.desc}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
