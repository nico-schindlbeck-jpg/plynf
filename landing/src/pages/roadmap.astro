---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CTA from "../components/CTA.astro";

const lastUpdated = "May 2026";

type Status = "shipped" | "in-progress" | "next" | "later";

interface Milestone {
  version: string;
  status: Status;
  eta: string;
  title: string;
  items: string[];
}

const milestones: Milestone[] = [
  {
    version: "v1.7",
    status: "shipped",
    eta: "May 2026",
    title: "Self-hostable runtime, API v1 stable",
    items: [
      "13 services (workspace, gateway, identity, dashboard, 8 OAuth-MCPs, mock-MCP)",
      "Workspace primitives: KV, files, versioned snapshots, branches",
      "Tool gateway with OAuth, caching, audit log, cost-caps",
      "Multi-agent channels with durable typed queues",
      "SDKs in Python, TypeScript, Go, Swift, Kotlin (API parity tracked)",
      "Apache 2.0 license, ~2,600 tests green",
    ],
  },
  {
    version: "v1.7.5",
    status: "shipped",
    eta: "May 2026",
    title: "Marketing surface complete",
    items: [
      "Landing page with manifesto, pricing, about",
      "Legal pages: privacy, terms, imprint, security",
      "PDF overview document",
      "Three primary colours design system",
    ],
  },
  {
    version: "v1.6 (distribution)",
    status: "in-progress",
    eta: "Q3 2026",
    title: "Click-to-install for non-technical users",
    items: [
      "GHCR-published images for all 13 services (multi-arch, cosign-signed)",
      "Single Go CLI binary, replaces 14-step make install",
      "Embedded mode: one binary, no Docker required",
      "First-run wizard, ≤ 3 clicks to running demo",
      "OAuth broker for GitHub, Linear, Notion (no client-secret needed)",
      "Tauri desktop app for macOS, Windows, Linux",
      "SDK publishing to PyPI, npm, Go module proxy",
    ],
  },
  {
    version: "v1.7 (distribution+)",
    status: "next",
    eta: "Q4 2026",
    title: "Three more OAuth providers",
    items: [
      "OAuth broker adds Slack, Atlassian, Asana (parallel approval lanes)",
      "Status page at status.plinth.dev",
      "Docs site at docs.plinth.dev (autogenerated from repo)",
      "Telemetry pipeline (opt-in, anonymous install pings)",
      "First Plinth Cloud beta — self-service signup, Stripe billing",
    ],
  },
  {
    version: "v2.0 (enterprise)",
    status: "later",
    eta: "Q1-Q2 2027",
    title: "Compliance and the last two providers",
    items: [
      "Google Workspace OAuth (CASA-assessed, sensitive scopes)",
      "Salesforce OAuth (AppExchange listing complete)",
      "SOC 2 Type II report",
      "DPA template, signed MSAs for enterprise customers",
      "On-prem deployment service",
      "Multi-region: EU and US data residency, sovereign-cloud options",
    ],
  },
];

const statusMeta: Record<Status, { label: string; class: string }> = {
  shipped: { label: "Shipped", class: "status-shipped" },
  "in-progress": { label: "In progress", class: "status-in-progress" },
  next: { label: "Next", class: "status-next" },
  later: { label: "Later", class: "status-later" },
};
---

<BaseLayout
  title="Roadmap · Plinth"
  description="Honest public roadmap for the Plinth runtime. What's shipped, what's in progress, what's next."
>
  <Nav />
  <main id="main">
    <section class="relative overflow-hidden">
      <div class="bg-grid"></div>
      <div class="bg-hero-glow"></div>
      <div class="container-narrow relative z-10 pt-20 pb-10 text-center">
        <p class="section-eyebrow">Roadmap</p>
        <h1 class="mt-3 font-semibold gradient-text text-balance" style="font-size: clamp(2.25rem, 5vw, 3.75rem); line-height: 1.05; letter-spacing: -0.04em;">
          What's shipped,<br/>
          <span class="gradient-text-accent">what's in flight,<br/>what's after that.</span>
        </h1>
        <p class="mt-6 text-ink-secondary text-lg max-w-xl mx-auto">
          We commit publicly so you can plan around us. If something on this page is missing or wrong, tell us.
        </p>
        <p class="mt-6 text-ink-muted text-sm font-mono uppercase tracking-widest">
          Last updated · {lastUpdated}
        </p>
      </div>
    </section>

    <section class="section pt-2">
      <div class="container-narrow" data-reveal>
        <div class="space-y-8">
          {
            milestones.map((m, i) => (
              <article class={`roadmap-card card p-7 sm:p-9 ${m.status === "in-progress" ? "glow-card" : ""}`}>
                <header class="flex flex-wrap items-center justify-between gap-3 mb-4">
                  <div class="flex items-center gap-3">
                    <span class={`status-pill ${statusMeta[m.status].class}`}>
                      {statusMeta[m.status].label}
                    </span>
                    <span class="text-2xs font-mono uppercase tracking-widest text-ink-muted">
                      {m.version} · {m.eta}
                    </span>
                  </div>
                  <span class="text-2xs font-mono text-ink-muted">
                    Milestone {i + 1} / {milestones.length}
                  </span>
                </header>
                <h2 class="text-xl sm:text-2xl font-semibold text-ink-primary tracking-tight">
                  {m.title}
                </h2>
                <ul class="mt-4 space-y-2 text-ink-secondary leading-relaxed">
                  {
                    m.items.map((item) => (
                      <li class="flex gap-3">
                        <span class="font-mono text-accent shrink-0">→</span>
                        <span>{item}</span>
                      </li>
                    ))
                  }
                </ul>
              </article>
            ))
          }
        </div>

        <div class="mt-12 card p-7 sm:p-8 text-center">
          <p class="section-eyebrow">Want a feature that isn't here?</p>
          <h2 class="mt-2 text-xl font-semibold text-ink-primary tracking-tight">
            Tell us. We commit to a response within a week.
          </h2>
          <p class="mt-3 text-ink-secondary">
            Open a discussion at
            <a href="https://github.com/nico-schindlbeck-jpg/plinth/discussions" class="text-accent hover:underline">github.com/plinth/plinth/discussions</a>
            or email
            <a href="mailto:hello@plinth.dev" class="text-accent hover:underline">hello@plinth.dev</a>.
          </p>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</BaseLayout>

<style>
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--border-strong);
  }
  .status-shipped {
    color: #93e0b2;
    border-color: rgba(147, 224, 178, 0.4);
    background: rgba(147, 224, 178, 0.08);
  }
  .status-in-progress {
    color: var(--accent);
    border-color: rgba(255, 133, 81, 0.4);
    background: rgba(255, 133, 81, 0.08);
  }
  .status-next {
    color: #d946ef;
    border-color: rgba(217, 70, 239, 0.4);
    background: rgba(217, 70, 239, 0.08);
  }
  .status-later {
    color: #b9b5d4;
    border-color: rgba(185, 181, 212, 0.32);
    background: rgba(185, 181, 212, 0.04);
  }
</style>
