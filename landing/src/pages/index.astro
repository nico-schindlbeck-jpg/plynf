---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import ShaderHero from "../components/ShaderHero.astro";
import Logos from "../components/Logos.astro";
import ProblemSolution from "../components/ProblemSolution.astro";
import AgentFlow from "../components/AgentFlow.astro";
import HowItWorks from "../components/HowItWorks.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import WorkspaceLifecycle from "../components/WorkspaceLifecycle.astro";
import CodeShowcase from "../components/CodeShowcase.astro";
import TokenEconomics from "../components/TokenEconomics.astro";
import MetricsBar from "../components/MetricsBar.astro";
import ChannelHandoff from "../components/ChannelHandoff.astro";
import Architecture from "../components/Architecture.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Plinth · The runtime for production AI agents"
  description="Plinth is the runtime where production AI agents actually work. Versioned workspace + tool gateway + multi-agent channels. Designed for AI agents, not retrofitted from human UIs. 71% fewer tokens. 2,867 tests. Apache 2.0."
>
  <Nav />
  <main id="main">
    <ShaderHero />
    <Logos />
    <ProblemSolution />
    <AgentFlow />
    <HowItWorks />
    <FeatureGrid />
    <WorkspaceLifecycle />
    <CodeShowcase />
    <TokenEconomics />
    <MetricsBar />
    <ChannelHandoff />
    <Architecture />
    <Pricing />
    <FAQ />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
