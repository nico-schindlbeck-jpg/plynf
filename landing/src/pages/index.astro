---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import ShaderHero from "../components/ShaderHero.astro";
import Logos from "../components/Logos.astro";
import ProblemSolution from "../components/ProblemSolution.astro";
import CustomerSupportDemo from "../components/CustomerSupportDemo.astro";
import IntegrationPaths from "../components/IntegrationPaths.astro";
import DataMinimization from "../components/DataMinimization.astro";
import AgentFlow from "../components/AgentFlow.astro";
import HowItWorks from "../components/HowItWorks.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import WorkspaceLifecycle from "../components/WorkspaceLifecycle.astro";
import CodeShowcase from "../components/CodeShowcase.astro";
import TokenEconomics from "../components/TokenEconomics.astro";
import BenchmarkBreadth from "../components/BenchmarkBreadth.astro";
import MetricsBar from "../components/MetricsBar.astro";
import ChannelHandoff from "../components/ChannelHandoff.astro";
import Architecture from "../components/Architecture.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Plynf · The optimization layer between AI agents and your business data"
  description="Your AI agent reads 200 fields. It only needs 8. Plynf sits between your AI agents and Salesforce, Slack, Jira, Drive, internal DBs — and cuts every tool response down to what the agent actually needs. 40–80% fewer tokens. Works with OpenAI, Claude, LangChain, n8n. Apache 2.0."
>
  <Nav />
  <main id="main">
    <ShaderHero />
    <Logos />
    <ProblemSolution />
    <CustomerSupportDemo />
    <IntegrationPaths />
    <DataMinimization />
    <AgentFlow />
    <HowItWorks />
    <FeatureGrid />
    <WorkspaceLifecycle />
    <CodeShowcase />
    <TokenEconomics />
    <BenchmarkBreadth />
    <MetricsBar />
    <ChannelHandoff />
    <Architecture />
    <Pricing />
    <FAQ />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
