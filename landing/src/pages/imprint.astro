---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Imprint · Plynf"
  description="Legal information as required by § 5 TMG."
>
  <Nav />
  <main id="main">
    <section class="relative overflow-hidden">
      <div class="bg-grid"></div>
      <div class="bg-hero-glow"></div>
      <div class="container-narrow relative z-10 pt-20 pb-10 text-center">
        <p class="section-eyebrow">Imprint · Impressum</p>
        <h1 class="mt-3 font-semibold gradient-text text-balance" style="font-size: clamp(2.25rem, 5vw, 3.75rem); line-height: 1.05; letter-spacing: -0.04em;">
          Who is responsible<br/>
          <span class="gradient-text-accent">for this website.</span>
        </h1>
      </div>
    </section>

    <section class="section pt-4">
      <article class="container-narrow" data-reveal>
        <div class="card p-8 sm:p-12 space-y-7 text-ink-secondary leading-relaxed">

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Information per § 5 TMG</h2>
            <p class="mt-3">
              Plynf GmbH<br/>
              Maximilianstraße 1<br/>
              80539 München<br/>
              Germany
            </p>
            <p class="mt-3">
              Commercial register: HRB 000000, Amtsgericht München<br/>
              VAT ID per § 27a UStG: DE000000000
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Represented by</h2>
            <p class="mt-3">
              Managing director: To be appointed
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Contact</h2>
            <p class="mt-3">
              Email: <a href="mailto:hello@plynf.com" class="text-accent hover:underline">hello@plynf.com</a><br/>
              Press: <a href="mailto:press@plynf.com" class="text-accent hover:underline">press@plynf.com</a><br/>
              Legal: <a href="mailto:legal@plynf.com" class="text-accent hover:underline">legal@plynf.com</a>
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Responsible for content per § 18 Abs. 2 MStV</h2>
            <p class="mt-3">
              Plynf GmbH (address above)
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">EU dispute resolution</h2>
            <p class="mt-3">
              The European Commission provides a platform for online dispute resolution at <a href="https://ec.europa.eu/consumers/odr" rel="noopener" class="text-accent hover:underline">ec.europa.eu/consumers/odr</a>. We are neither obliged nor willing to participate in dispute-resolution proceedings before a consumer arbitration board.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Liability for content</h2>
            <p class="mt-3">
              As a service provider we are responsible for our own content on these pages in accordance with § 7 (1) TMG and general law. According to §§ 8 to 10 TMG we are not obligated to monitor transmitted or stored third-party information. Obligations to remove or block the use of information under general laws remain unaffected.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Liability for links</h2>
            <p class="mt-3">
              Our site contains links to external websites whose content we have no influence over. We accept no liability for that content. The respective provider or operator is always responsible for the content of linked pages.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-ink-primary tracking-tight">Copyright</h2>
            <p class="mt-3">
              The runtime source code is licensed under Apache 2.0 and may be used, modified, and redistributed under those terms. The marketing website content (copy, illustrations, logo) is © Plynf GmbH unless otherwise marked.
            </p>
          </div>

          <p class="text-xs text-ink-muted pt-4 border-t border-border">
            This page contains placeholder values. Replace before going live.
          </p>

        </div>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>
