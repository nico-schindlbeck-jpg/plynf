{
  "name": "@plinth/sdk",
  "version": "0.3.0",
  "description": "Plinth TypeScript SDK — the agent-native runtime client",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src tests"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^25.6.2"
  },
  "keywords": ["ai", "agents", "mcp", "tools", "workspace", "llm"]
}
